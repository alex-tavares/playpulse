# Local development defaults. Do not use these values in production.
PLAYPULSE_DATABASE_URL=postgresql://playpulse:playpulse@localhost:5432/playpulse

PLAYPULSE_INGEST_HOST=0.0.0.0
PLAYPULSE_INGEST_PORT=4001
PLAYPULSE_INGEST_ALLOWED_ORIGINS=http://localhost:3000
PLAYPULSE_INGEST_TRUST_PROXY=false
PLAYPULSE_INGEST_API_KEYS_JSON=[]
PLAYPULSE_INGEST_AUTH_MODES=hmac
PLAYPULSE_INGEST_TOKEN_SIGNING_SECRET=
PLAYPULSE_INGEST_PUBLIC_CLIENTS_JSON=[]

PLAYPULSE_ANALYTICS_HOST=0.0.0.0
PLAYPULSE_ANALYTICS_PORT=4002
PLAYPULSE_ANALYTICS_ALLOWED_ORIGINS=http://localhost:3000
PLAYPULSE_ANALYTICS_TRUST_PROXY=false
PLAYPULSE_ANALYTICS_PRIVATE_BEARER_TOKEN=playpulse-local-private-token

PLAYPULSE_RATE_LIMIT_PER_KEY=600
PLAYPULSE_RATE_LIMIT_PER_KEY_BURST=1200
PLAYPULSE_RATE_LIMIT_PER_IP=120
PLAYPULSE_RATE_LIMIT_PER_IP_BURST=240
PLAYPULSE_REPLAY_WINDOW_SECONDS=300
PLAYPULSE_STORAGE_RETENTION_DAYS=90
