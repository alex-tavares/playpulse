# Copy to .env.production on the deployment host and replace every placeholder.
# Never commit .env.production or real secret values.

PLAYPULSE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

PLAYPULSE_INGEST_HOST=0.0.0.0
PLAYPULSE_INGEST_PORT=4001
PLAYPULSE_INGEST_ALLOWED_ORIGINS=https://YOUR-CONSUMER-ORIGIN.example
PLAYPULSE_INGEST_TRUST_PROXY=true
PLAYPULSE_INGEST_API_KEYS_JSON=[{"key_id":"REPLACE_WITH_KEY_ID","signing_secret":"REPLACE_WITH_SIGNING_SECRET","game_id":"mythclash","enabled":true}]

PLAYPULSE_ANALYTICS_HOST=0.0.0.0
PLAYPULSE_ANALYTICS_PORT=4002
PLAYPULSE_ANALYTICS_ALLOWED_ORIGINS=https://YOUR-CONSUMER-ORIGIN.example
PLAYPULSE_ANALYTICS_TRUST_PROXY=true
PLAYPULSE_ANALYTICS_PRIVATE_BEARER_TOKEN=REPLACE_WITH_STRONG_PRIVATE_TOKEN

PLAYPULSE_RATE_LIMIT_PER_KEY=600
PLAYPULSE_RATE_LIMIT_PER_KEY_BURST=1200
PLAYPULSE_RATE_LIMIT_PER_IP=120
PLAYPULSE_RATE_LIMIT_PER_IP_BURST=240
PLAYPULSE_REPLAY_WINDOW_SECONDS=300
PLAYPULSE_STORAGE_RETENTION_DAYS=90
