{
  "name": "playpulse",
  "private": true,
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "build": "pnpm -r run build --if-present",
    "dev": "pnpm -r run dev --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs",
    "typecheck": "tsc --project tsconfig.base.json --noEmit"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
